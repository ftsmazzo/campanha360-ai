generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
  COMPLIANCE
  VIEWER
}

enum CampaignPhase {
  PRE_CAMPAIGN
  INTRA_PARTY
  OFFICIAL_CAMPAIGN
  RUNOFF
  CLOSED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ContactStatus {
  ACTIVE
  INVALID
  DUPLICATE
  BLOCKED
  DELETED
}

enum ChannelType {
  WHATSAPP
  EMAIL
  SMS
  TELEGRAM
  INSTAGRAM
}

enum ConsentStatus {
  UNKNOWN
  GRANTED
  REVOKED
  OPT_OUT
}

enum ContactTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum ContactOperationalStatus {
  NEW
  IN_PROGRESS
  SUPPORTER
  UNDECIDED
  OPPOSED
  INVALID
  ARCHIVED
}

enum ChannelProvider {
  WHATSAPP_EVOLUTION
  WHATSAPP_CLOUD_API
  INSTAGRAM
  EMAIL
  SMS
  TELEGRAM
}

enum ChannelAccountStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
  ARCHIVED
}

enum DispatchPlanStatus {
  DRAFT
  VALIDATING
  VALIDATED
  BLOCKED
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
}

enum DispatchPlanRecipientEligibilityStatus {
  ELIGIBLE
  EXCLUDED_OPT_OUT
  EXCLUDED_BLOCKED
  EXCLUDED_DELETED
  EXCLUDED_INVALID_DESTINATION
  EXCLUDED_DUPLICATE
  EXCLUDED_NO_CHANNEL
  EXCLUDED_POLICY
  EXCLUDED_OTHER
}

enum DispatchStatus {
  DRAFT
  PREPARING
  READY
  QUEUED
  RUNNING
  PAUSING
  PAUSED
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  CANCELED
  EMERGENCY_STOPPED
}

enum DispatchItemStatus {
  PENDING
  SCHEDULED
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  READ
  RETRY_SCHEDULED
  FAILED
  SKIPPED
  CANCELED
  UNKNOWN_PROVIDER_STATE
}

enum DispatchItemErrorCategory {
  TRANSIENT_NETWORK
  PROVIDER_RATE_LIMIT
  PROVIDER_UNAVAILABLE
  PROVIDER_TIMEOUT
  CHANNEL_DISCONNECTED
  AUTHENTICATION_ERROR
  INVALID_DESTINATION
  CONTENT_REJECTED
  CONTACT_OPT_OUT
  CONTACT_BLOCKED
  CONTACT_DELETED
  DISPATCH_PAUSED
  DISPATCH_CANCELED
  OUTSIDE_WINDOW
  DUPLICATE_PREVENTED
  UNKNOWN
}

enum ProtectionProfile {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  CUSTOM
}

enum DistributionStrategy {
  CAPACITY_WEIGHTED
}

enum DispatchChannelOperationalStatus {
  READY
  COOLDOWN
  DISCONNECTED
  ARCHIVED
  CAPACITY_EXHAUSTED
  BLOCKED
  DISABLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum AiMode {
  SUGGEST_ONLY
  AUTO_LOW_RISK
  DISABLED
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  passwordHash String
  status       UserStatus       @default(ACTIVE)
  memberships  Membership[]
  auditLogs    AuditLog[]
  createdDispatchPlans DispatchPlan[] @relation("DispatchPlanCreatedBy")
  approvedDispatchPlans DispatchPlan[] @relation("DispatchPlanApprovedBy")
  rejectedDispatchPlans DispatchPlan[] @relation("DispatchPlanRejectedBy")
  canceledDispatchPlans DispatchPlan[] @relation("DispatchPlanCanceledBy")
  createdDispatches Dispatch[] @relation("DispatchCreatedBy")
  contactNotes ContactNote[]
  createdContactTasks ContactTask[] @relation("ContactTaskCreatedBy")
  assignedContactTasks ContactTask[] @relation("ContactTaskAssignedTo")
  assignedContacts Contact[] @relation("ContactOperationalAssignee")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Organization {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  status      OrganizationStatus @default(ACTIVE)
  memberships Membership[]
  campaigns   Campaign[]
  dispatchPlans DispatchPlan[]
  dispatchPlanRecipients DispatchPlanRecipient[]
  dispatchPlanChannels DispatchPlanChannel[]
  dispatches Dispatch[]
  dispatchItems DispatchItem[]
  dispatchChannels DispatchChannel[]
  dispatchChannelUsageDaily DispatchChannelUsageDaily[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole
  user           User           @relation(fields: [userId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
}

model Campaign {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  electionYear   Int
  office         String
  territory      String?
  phase          CampaignPhase      @default(PRE_CAMPAIGN)
  status         CampaignStatus     @default(DRAFT)
  organization   Organization       @relation(fields: [organizationId], references: [id])
  candidate      Candidate?
  contacts       Contact[]
  dispatchPlans  DispatchPlan[]
  dispatchPlanRecipients DispatchPlanRecipient[]
  dispatchPlanChannels DispatchPlanChannel[]
  dispatches     Dispatch[]
  dispatchItems  DispatchItem[]
  dispatchChannels DispatchChannel[]
  dispatchChannelUsageDaily DispatchChannelUsageDaily[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Candidate {
  id               String   @id @default(cuid())
  organizationId   String
  campaignId       String   @unique
  name             String
  party            String?
  office           String?
  bio              String?
  toneOfVoice      String?
  mainProposals    Json?
  restrictedTopics Json?
  campaign         Campaign @relation(fields: [campaignId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Contact {
  id             String          @id @default(cuid())
  organizationId String
  campaignId     String
  name           String?
  phoneNumber    String?
  email          String?
  city           String?
  neighborhood   String?
  metadata       Json?
  status         ContactStatus              @default(ACTIVE)
  operationalStatus ContactOperationalStatus @default(NEW)
  assignedToUserId String?
  assignedTo     User?                      @relation("ContactOperationalAssignee", fields: [assignedToUserId], references: [id])
  campaign       Campaign                   @relation(fields: [campaignId], references: [id])
  channels       ContactChannel[]
  consents       Consent[]
  optOuts        OptOut[]
  tags           ContactTag[]
  notes          ContactNote[]
  tasks          ContactTask[]
  dispatchPlanRecipients DispatchPlanRecipient[]
  dispatchItems  DispatchItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, campaignId])
  @@index([phoneNumber])
  @@index([email])
}

model ContactChannel {
  id              String      @id @default(cuid())
  organizationId  String
  campaignId      String
  contactId       String
  channel         ChannelType
  value           String
  normalizedValue String
  isPrimary       Boolean     @default(false)
  status          String      @default("ACTIVE")
  contact         Contact     @relation(fields: [contactId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([organizationId, campaignId, channel])
}

model Consent {
  id             String        @id @default(cuid())
  organizationId String
  campaignId     String
  contactId      String
  channel        ChannelType
  status         ConsentStatus @default(UNKNOWN)
  source         String?
  consentText    String?
  collectedAt    DateTime?
  revokedAt      DateTime?
  contact        Contact       @relation(fields: [contactId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OptOut {
  id             String      @id @default(cuid())
  organizationId String
  campaignId     String
  contactId      String
  channel        ChannelType?
  reason         String?
  source         String?
  contact        Contact     @relation(fields: [contactId], references: [id])
  createdAt      DateTime    @default(now())
}

model Tag {
  id             String       @id @default(cuid())
  organizationId String
  campaignId     String
  name           String
  color          String?
  description    String?
  contacts       ContactTag[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([campaignId, name])
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])
  createdAt DateTime @default(now())

  @@id([contactId, tagId])
}

model ContactNote {
  id             String   @id @default(cuid())
  organizationId String
  campaignId     String
  contactId      String
  authorUserId   String
  body           String
  contact        Contact  @relation(fields: [contactId], references: [id])
  author         User     @relation(fields: [authorUserId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, campaignId, contactId])
}

model ContactTask {
  id               String            @id @default(cuid())
  organizationId   String
  campaignId       String
  contactId        String
  createdByUserId  String
  assignedToUserId String?
  title            String
  description      String?
  status           ContactTaskStatus @default(OPEN)
  dueAt            DateTime?
  completedAt      DateTime?
  contact          Contact           @relation(fields: [contactId], references: [id])
  createdBy        User              @relation("ContactTaskCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo       User?             @relation("ContactTaskAssignedTo", fields: [assignedToUserId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([organizationId, campaignId, contactId])
  @@index([organizationId, campaignId, status])
}

model ChannelAccount {
  id                String               @id @default(cuid())
  organizationId    String
  campaignId        String
  provider          ChannelProvider
  name              String
  status            ChannelAccountStatus @default(DISCONNECTED)
  externalAccountId String?
  config            Json?
  dispatchPlans     DispatchPlan[]
  dispatchPlanChannels DispatchPlanChannel[]
  dispatches        Dispatch[]
  dispatchItems     DispatchItem[]
  dispatchChannels  DispatchChannel[]
  dispatchChannelUsageDaily DispatchChannelUsageDaily[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([organizationId, campaignId])
}

model ConversationThread {
  id                 String    @id @default(cuid())
  organizationId     String
  campaignId         String
  contactId          String
  channelAccountId   String?
  channel            ChannelType
  status             String    @default("OPEN")
  assignedToUserId   String?
  lastMessageAt      DateTime?
  summary            String?
  messages           Message[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([organizationId, campaignId, channelAccountId, contactId])
}

model Message {
  id                String            @id @default(cuid())
  organizationId    String
  campaignId        String
  contactId         String?
  conversationId    String?
  channelAccountId  String?
  provider          ChannelProvider
  direction         MessageDirection
  externalMessageId String?
  body              String?
  status            String            @default("PENDING")
  rawPayload        Json?
  conversation      ConversationThread? @relation(fields: [conversationId], references: [id])
  createdAt         DateTime          @default(now())

  @@index([organizationId, campaignId, externalMessageId])
  @@index([organizationId, campaignId, channelAccountId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  campaignId     String?
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  actor          User?    @relation(fields: [actorUserId], references: [id])
  createdAt      DateTime @default(now())
}

model Segment {
  id              String   @id @default(cuid())
  organizationId  String
  campaignId      String
  name            String
  description     String?
  filters         Json
  createdByUserId String?
  dispatchPlans   DispatchPlan[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([campaignId, name])
  @@index([organizationId, campaignId])
}

model DispatchPlan {
  id               String             @id @default(cuid())
  organizationId   String
  campaignId       String
  segmentId        String
  channelAccountId String
  name             String
  description      String?
  channelType      ChannelType
  content          String
  status           DispatchPlanStatus @default(DRAFT)
  version          Int                @default(1)
  totalEvaluated   Int                @default(0)
  totalEligible    Int                @default(0)
  totalExcluded    Int                @default(0)
  snapshotCreatedAt DateTime?
  filtersSnapshot  Json?
  validationSnapshot Json?
  validatedAt      DateTime?
  validatedVersion Int?
  simulationSnapshot Json?
  simulatedAt      DateTime?
  simulatedVersion Int?
  approvedByUserId String?
  approvedAt       DateTime?
  approvalSnapshot Json?
  rejectedByUserId String?
  rejectedAt       DateTime?
  rejectionReason  String?
  canceledByUserId String?
  canceledAt       DateTime?
  cancellationReason String?
  createdByUserId  String
  organization     Organization       @relation(fields: [organizationId], references: [id])
  campaign         Campaign           @relation(fields: [campaignId], references: [id])
  segment          Segment            @relation(fields: [segmentId], references: [id])
  channelAccount   ChannelAccount     @relation(fields: [channelAccountId], references: [id])
  createdBy        User               @relation("DispatchPlanCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy       User?              @relation("DispatchPlanApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy       User?              @relation("DispatchPlanRejectedBy", fields: [rejectedByUserId], references: [id])
  canceledBy       User?              @relation("DispatchPlanCanceledBy", fields: [canceledByUserId], references: [id])
  recipients       DispatchPlanRecipient[]
  planChannels     DispatchPlanChannel[]
  dispatches       Dispatch[]
  dispatchItems    DispatchItem[]
  protectionPolicySnapshot Json?
  legacySingleChannel Boolean           @default(true)
  multiInstanceEnabled Boolean          @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId, campaignId])
  @@index([campaignId, status])
  @@index([segmentId])
  @@index([channelAccountId])
  @@index([approvedByUserId])
  @@index([rejectedByUserId])
  @@index([canceledByUserId])
}

model DispatchPlanChannel {
  id                   String   @id @default(cuid())
  organizationId       String
  campaignId           String
  dispatchPlanId       String
  channelAccountId     String
  enabled              Boolean  @default(true)
  priority             Int      @default(100)
  weight               Int      @default(100)
  dailyLimit           Int      @default(200)
  hourlyLimit          Int?
  newAccountDailyLimit Int      @default(50)
  warmupDailyLimit     Int      @default(20)
  assignedCapacity     Int      @default(0)
  assignedRecipients   Int      @default(0)
  configurationSnapshot Json?
  healthSnapshot       Json?
  organization         Organization   @relation(fields: [organizationId], references: [id])
  campaign             Campaign       @relation(fields: [campaignId], references: [id])
  dispatchPlan         DispatchPlan   @relation(fields: [dispatchPlanId], references: [id], onDelete: Cascade)
  channelAccount       ChannelAccount @relation(fields: [channelAccountId], references: [id])
  dispatchChannels     DispatchChannel[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([dispatchPlanId, channelAccountId])
  @@index([dispatchPlanId])
  @@index([organizationId, campaignId])
  @@index([channelAccountId])
}

model DispatchPlanRecipient {
  id                    String                                  @id @default(cuid())
  organizationId        String
  campaignId            String
  dispatchPlanId        String
  contactId             String
  destination           String
  normalizedDestination String
  eligibilityStatus     DispatchPlanRecipientEligibilityStatus
  exclusionReason       String?
  contactSnapshot       Json
  consentSnapshot       Json?
  optOutSnapshot        Json?
  organization          Organization                            @relation(fields: [organizationId], references: [id])
  campaign              Campaign                                @relation(fields: [campaignId], references: [id])
  dispatchPlan          DispatchPlan                            @relation(fields: [dispatchPlanId], references: [id], onDelete: Cascade)
  contact               Contact                                 @relation(fields: [contactId], references: [id])
  dispatchItems         DispatchItem[]
  createdAt             DateTime                                @default(now())

  @@unique([dispatchPlanId, contactId, normalizedDestination])
  @@index([dispatchPlanId])
  @@index([dispatchPlanId, eligibilityStatus])
  @@index([organizationId, campaignId])
  @@index([contactId])
  @@index([normalizedDestination])
}

model Dispatch {
  id                    String         @id @default(cuid())
  organizationId        String
  campaignId            String
  dispatchPlanId        String         @unique
  channelAccountId      String
  name                  String
  description           String?
  channelType           ChannelType
  contentSnapshot       Json
  configurationSnapshot Json
  approvalSnapshot      Json
  status                DispatchStatus @default(DRAFT)
  totalItems            Int            @default(0)
  pendingItems          Int            @default(0)
  queuedItems           Int            @default(0)
  processingItems       Int            @default(0)
  sentItems             Int            @default(0)
  deliveredItems        Int            @default(0)
  readItems             Int            @default(0)
  failedItems           Int            @default(0)
  skippedItems          Int            @default(0)
  canceledItems         Int            @default(0)
  createdByUserId       String
  preparedAt            DateTime?
  queuedAt              DateTime?
  startedAt             DateTime?
  pausingAt             DateTime?
  pausedAt              DateTime?
  resumedAt             DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  canceledAt            DateTime?
  emergencyStoppedAt    DateTime?
  lastProgressAt        DateTime?
  organization          Organization   @relation(fields: [organizationId], references: [id])
  campaign              Campaign       @relation(fields: [campaignId], references: [id])
  dispatchPlan          DispatchPlan   @relation(fields: [dispatchPlanId], references: [id])
  channelAccount        ChannelAccount @relation(fields: [channelAccountId], references: [id])
  createdBy             User           @relation("DispatchCreatedBy", fields: [createdByUserId], references: [id])
  items                 DispatchItem[]
  channels              DispatchChannel[]
  requiringRedistribution Boolean      @default(false)
  multiInstance         Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([organizationId, campaignId])
  @@index([campaignId, status])
  @@index([dispatchPlanId])
  @@index([channelAccountId])
  @@index([status, createdAt])
}

model DispatchChannel {
  id                    String                          @id @default(cuid())
  organizationId        String
  campaignId            String
  dispatchId            String
  dispatchPlanChannelId String
  channelAccountId      String
  enabled               Boolean                         @default(true)
  priority              Int                             @default(100)
  weight                Int                             @default(100)
  effectiveDailyLimit   Int                             @default(0)
  assignedItems         Int                             @default(0)
  processedItems        Int                             @default(0)
  sentItems             Int                             @default(0)
  failedItems           Int                             @default(0)
  consecutiveErrors     Int                             @default(0)
  cooldownUntil         DateTime?
  operationalStatus     DispatchChannelOperationalStatus @default(READY)
  configurationSnapshot Json?
  organization          Organization                    @relation(fields: [organizationId], references: [id])
  campaign              Campaign                        @relation(fields: [campaignId], references: [id])
  dispatch              Dispatch                        @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  dispatchPlanChannel   DispatchPlanChannel             @relation(fields: [dispatchPlanChannelId], references: [id])
  channelAccount        ChannelAccount                  @relation(fields: [channelAccountId], references: [id])
  items                 DispatchItem[]                  @relation("DispatchItemChannel")
  originalItems         DispatchItem[]                  @relation("DispatchItemOriginalChannel")
  usageDaily            DispatchChannelUsageDaily[]
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  @@unique([dispatchId, channelAccountId])
  @@index([dispatchId])
  @@index([organizationId, campaignId])
  @@index([channelAccountId])
  @@index([operationalStatus])
}

/**
 * Contador diario de envio por instancia (DispatchChannel), usado pelo
 * Worker (subetapa 09.4) para: (a) incrementar sentCount/failedCount de
 * forma atomica no sucesso/erro; (b) decidir rotacao (rotateEveryMessages)
 * e respeito ao delay minimo entre envios do mesmo canal (lastSentAt).
 */
model DispatchChannelUsageDaily {
  id                String          @id @default(cuid())
  organizationId    String
  campaignId        String
  dispatchChannelId String
  channelAccountId  String
  usageDate         DateTime        @db.Date
  sentCount         Int             @default(0)
  failedCount       Int             @default(0)
  lastSentAt        DateTime?
  organization      Organization    @relation(fields: [organizationId], references: [id])
  campaign          Campaign        @relation(fields: [campaignId], references: [id])
  dispatchChannel   DispatchChannel @relation(fields: [dispatchChannelId], references: [id], onDelete: Cascade)
  channelAccount    ChannelAccount  @relation(fields: [channelAccountId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([dispatchChannelId, usageDate])
  @@index([organizationId, campaignId])
  @@index([channelAccountId, usageDate])
}

model DispatchItem {
  id                      String                     @id @default(cuid())
  organizationId          String
  campaignId              String
  dispatchId              String
  dispatchPlanId          String
  dispatchPlanRecipientId String
  contactId               String
  channelAccountId        String
  dispatchChannelId       String?
  originalDispatchChannelId String?
  reassignmentCount       Int                        @default(0)
  lastReassignedAt        DateTime?
  destination             String
  normalizedDestination   String
  contactSnapshot         Json
  contentSnapshot         Json
  status                  DispatchItemStatus         @default(PENDING)
  attemptCount            Int                        @default(0)
  maxAttempts             Int                        @default(3)
  scheduledAt             DateTime?
  queuedAt                DateTime?
  lockedAt                DateTime?
  lockToken               String?
  lockExpiresAt           DateTime?
  startedAt               DateTime?
  sentAt                  DateTime?
  deliveredAt             DateTime?
  readAt                  DateTime?
  failedAt                DateTime?
  skippedAt               DateTime?
  canceledAt              DateTime?
  providerMessageId       String?
  providerStatus          String?
  errorCategory           DispatchItemErrorCategory?
  errorCode               String?
  errorMessage            String?
  lastAttemptAt           DateTime?
  nextRetryAt             DateTime?
  queueJobId              String?
  queueName               String?
  queueCreatedAt          DateTime?
  technicalValidatedAt    DateTime?
  lastQueueError          String?
  metadata                Json?
  organization            Organization               @relation(fields: [organizationId], references: [id])
  campaign                Campaign                   @relation(fields: [campaignId], references: [id])
  dispatch                Dispatch                   @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  dispatchPlan            DispatchPlan               @relation(fields: [dispatchPlanId], references: [id])
  dispatchPlanRecipient   DispatchPlanRecipient      @relation(fields: [dispatchPlanRecipientId], references: [id])
  contact                 Contact                    @relation(fields: [contactId], references: [id])
  channelAccount          ChannelAccount             @relation(fields: [channelAccountId], references: [id])
  dispatchChannel         DispatchChannel?           @relation("DispatchItemChannel", fields: [dispatchChannelId], references: [id])
  originalDispatchChannel DispatchChannel?           @relation("DispatchItemOriginalChannel", fields: [originalDispatchChannelId], references: [id])
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  @@unique([dispatchId, dispatchPlanRecipientId])
  @@unique([dispatchId, normalizedDestination])
  @@index([dispatchId])
  @@index([dispatchId, status])
  @@index([organizationId, campaignId])
  @@index([channelAccountId, status])
  @@index([dispatchChannelId])
  @@index([contactId])
  @@index([normalizedDestination])
  @@index([providerMessageId])
  @@index([nextRetryAt])
  @@index([lockedAt])
  @@index([createdAt])
  @@index([queueJobId])
}
