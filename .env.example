# Campanha360 AI — variaveis de ambiente
# Copie para .env no desenvolvimento local. Em producao, configure no painel do EasyPanel.
# Nunca commite .env nem valores reais de senha, JWT ou tokens.

# --- API (apps/api) ---
DATABASE_URL=postgresql://campanha360:<POSTGRES_PASSWORD>@localhost:5432/campanha360_ai
REDIS_URL=redis://default:<REDIS_PASSWORD>@localhost:6379
PORT=3001
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
JWT_SECRET=<JWT_SECRET>
JWT_EXPIRES_IN=7d
EVOLUTION_API_URL=https://infra-core-whatsapp-core.kxryyk.easypanel.host
# Necessaria para status/QR/prepare e envio manual (04.6). Nunca grave no banco nem retorne pela API.
EVOLUTION_API_KEY=<EVOLUTION_API_KEY>
# Opcional. Se definido, o webhook exige autenticacao Evolution (JWT via jwt_key).
# No prepare, a API sincroniza automaticamente na Evolution:
#   webhook.url = {API_PUBLIC_URL}/webhooks/evolution/{channelAccountId}
#   webhook.headers.jwt_key = <EVOLUTION_WEBHOOK_SECRET>
# A Evolution envia Authorization: Bearer <JWT HS256> (claims app=evolution, action=webhook).
# Alternativa manual: header estatico x-evolution-webhook-secret com o mesmo valor.
# Sem este valor, o endpoint publico aceita webhooks sem autenticacao (apenas homologacao/teste).
# Requer API_PUBLIC_URL correto para o sync no prepare.
EVOLUTION_WEBHOOK_SECRET=<EVOLUTION_WEBHOOK_SECRET>
NODE_ENV=development

# Fila de disparo (BullMQ/Redis, subetapa 09.3). Defaults: todas false.
# DISPATCH_SEND_ENABLED NUNCA deve ter default/valor true sem validacao explicita.
# DISPATCH_ENGINE_ENABLED=false
# DISPATCH_QUEUE_ENABLED=false
# DISPATCH_SEND_ENABLED=false

# EasyPanel (API) — use os hosts internos e senhas geradas no painel:
# DATABASE_URL=postgresql://campanha360:<POSTGRES_PASSWORD>@campanha-360-ia_postgres:5432/campanha360_ai?sslmode=disable
# REDIS_URL=redis://default:<REDIS_PASSWORD>@campanha-360-ia_redis:6379
# WEB_PUBLIC_URL=https://campanha-360-ia-web.kxryyk.easypanel.host
# API_PUBLIC_URL=https://campanha-360-ia-api.kxryyk.easypanel.host
# JWT_SECRET=<JWT_SECRET>
# NODE_ENV=production

# --- Web (apps/web) ---
# PORT=3000
# WEB_PUBLIC_URL=http://localhost:3000
# API_PUBLIC_URL=http://localhost:3001
# NODE_ENV=development

