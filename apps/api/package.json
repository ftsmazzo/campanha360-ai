{
  "name": "@campanha360/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test:webhook-auth": "npx --yes tsx --test src/webhooks/evolution-webhook.auth.spec.ts",
    "test:inbox-reply": "npx --yes tsx --test src/inbox/inbox-reply.util.spec.ts",
    "test:contact-interaction": "npx --yes tsx --test src/contacts/contact-interaction.util.spec.ts",
    "test:contact-opt-out": "npx --yes tsx --test src/contacts/contact-opt-out.util.spec.ts",
    "test:contact-tag": "npx --yes tsx --test src/contacts/contact-tag.util.spec.ts",
    "test:contact-import": "npx --yes tsx --test src/contacts/contact-import.util.spec.ts",
    "test:contact-removal": "npx --yes tsx --test src/contacts/contact-removal.util.spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
